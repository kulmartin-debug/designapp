{
  "name": "pred-po-vizualizator-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run tests/unit",
    "pretest:e2e": "cross-env DATABASE_URL=file:./tests/test.db npx prisma migrate deploy",
    "test:e2e": "cross-env DATABASE_URL=file:./tests/test.db vitest run tests/e2e"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "prisma": "^6.16.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
