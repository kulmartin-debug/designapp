# Skopírujte tento súbor ako backend/.env a doplňte hodnoty.
# Ak API kľúč pre providera chýba, appka automaticky použije MOCK provider
# (vráti placeholder obrázok, actualCostUsd = 0) - appka je tak plne
# funkčná/prezerateľná aj bez akýchkoľvek AI kľúčov. AI kľúče sa navyše dajú
# nastaviť aj priamo v appke cez /nastavenia (uložia sa zašifrované do DB
# a majú prednosť pred týmito .env hodnotami).

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Databáza (Prisma, PostgreSQL) ---
# Napr. free Supabase projekt: Project Settings -> Database -> Connection string (URI, "Transaction" pooler).
DATABASE_URL="postgresql://postgres:[HESLO]@[PROJECT-REF].supabase.co:5432/postgres"

# --- Úložisko súborov ---
# "local" = disk v backend/uploads (rýchly štart, žiadny účet netreba).
# "s3"    = S3-kompatibilné úložisko, napr. Supabase Storage (Storage -> Settings -> S3 Connection).
STORAGE_DRIVER=local
UPLOADS_DIR=./uploads

# Potrebné len keď STORAGE_DRIVER=s3:
S3_ENDPOINT=https://[PROJECT-REF].supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- AI providers (voliteľné - dajú sa nastaviť aj cez /nastavenia v appke) ---
# Replicate - https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# fal.ai - https://fal.ai/dashboard/keys
FAL_API_KEY=

# Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Predvolený provider pre nové joby, ak klient v requeste neuvedie provider=...
DEFAULT_PROVIDER=MOCK

# --- Prihlasovanie (jednotné heslo pre celú appku) ---
# Prázdne = appka je bez hesla (len pre lokálny vývoj!). V produkcii VŽDY nastavte.
ACCESS_PASSWORD=

# Podpisuje prihlasovaciu session cookie. V produkcii VŽDY nastavte na dlhý
# náhodný reťazec (napr. `openssl rand -hex 32`), inak sa po každom
# reštarte/redeploy všetci odhlásia. (Render.yaml si toto generuje sám.)
SESSION_SECRET=

# Šifruje uložené AI API kľúče v databáze. V produkcii VŽDY nastavte a
# nemeňte - inak sa po reštarte/redeploy uložené kľúče nebudú dať dešifrovať
# a bude ich treba zadať znova cez /nastavenia. (Render.yaml si toto generuje sám.)
CREDENTIALS_ENCRYPTION_KEY=

# Potrebné len ak frontend a backend bežia na rôznych doménach/origin.
# Ak backend servíruje aj build frontendu (produkcia, jedna Render služba),
# toto sa nepoužíva.
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:4000
